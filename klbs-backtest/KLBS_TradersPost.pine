//@version=6
indicator("Key Level Breakout System", overlay=true, max_lines_count=500, max_labels_count=500, max_boxes_count=300)

// ══════════════════════════════════════════════════════════════════════════════
// ML FILTER INDICATORS - These are sent to the ML API for filtering decisions
// ══════════════════════════════════════════════════════════════════════════════
rsi_val = ta.rsi(close, 14)
rsi_roc = rsi_val - rsi_val[3]  // RSI rate of change over 3 bars - KEY MOMENTUM FEATURE
[macd_line, macd_signal, macd_hist] = ta.macd(close, 12, 26, 9)
[diplus, diminus, adx_val] = ta.dmi(14, 14)
atr_val = ta.atr(14)
atr_pct = (atr_val / close) * 100

var string G0 = "── Instrument Preset ─────────────────"
presetMode = input.string("Auto", "Preset Mode", options=["Auto", "MNQ", "M2K", "MES", "MGC", "ZN", "ZB", "6E", "6J", "Manual"], group=G0)

_ticker     = str.upper(syminfo.ticker)
_autoPreset = str.contains(_ticker, "MNQ") ? "MNQ" :
              str.contains(_ticker, "M2K") ? "M2K" :
              str.contains(_ticker, "MES") ? "MES" :
              str.contains(_ticker, "MGC") ? "MGC" :
              str.contains(_ticker, "ZN")  ? "ZN"  :
              str.contains(_ticker, "ZB")  ? "ZB"  :
              str.contains(_ticker, "6E")  ? "6E"  :
              str.contains(_ticker, "6J")  ? "6J"  : "Manual"
_preset     = presetMode == "Auto" ? _autoPreset : presetMode

// ── OPTIMIZED PARAMETERS (OOS Validated) ──────────────────────────────────────
// Micros: MNQ/MES/MGC in pts | Bonds: ZN/ZB in 32nds | Currencies: 6E/6J in pips
_presetTP = _preset == "MNQ" ? 50.0 : _preset == "M2K" ? 10.0 : _preset == "MES" ? 25.0 : _preset == "MGC" ? 20.0 : _preset == "ZN" ? 0.20 : _preset == "ZB" ? 0.50 : _preset == "6E" ? 0.003 : _preset == "6J" ? 0.00004 : 50.0

_presetSL = _preset == "MNQ" ? 50.0 : _preset == "M2K" ? 10.0 : _preset == "MES" ? 25.0 : _preset == "MGC" ? 25.0 : _preset == "ZN" ? 0.30 : _preset == "ZB" ? 0.50 : _preset == "6E" ? 0.0025 : _preset == "6J" ? 0.00007 : 50.0

_presetPV = _preset == "MNQ" ? 2.0 : _preset == "M2K" ? 5.0 : _preset == "MES" ? 5.0 : _preset == "MGC" ? 10.0 : _preset == "ZN" ? 1000.0 : _preset == "ZB" ? 1000.0 : _preset == "6E" ? 125000.0 : _preset == "6J" ? 125000.0 : 2.0

_presetRZ = _preset == "M2K" ? 2.0 : _preset == "MGC" ? 3.0 : _preset == "ZN" ? 0.03 : _preset == "ZB" ? 0.05 : _preset == "6E" ? 0.0005 : _preset == "6J" ? 0.00001 : 5.0

_presetTrail = _preset == "ZN" ? 0.03 : _preset == "ZB" ? 0.05 : _preset == "6E" ? 0.0005 : _preset == "6J" ? 0.00001 : 5.0

var string G1 = "── Manual Risk (only used in Manual mode) ──"
manualTP  = input.float(35.0, "Take Profit (pts)", minval=1.0, step=1.0, group=G1)
manualSL  = input.float(50.0, "Stop Loss (pts)",   minval=1.0, step=1.0, group=G1)
manualRZ  = input.float(5.0,  "Retest Zone (pts)", minval=0.5, step=0.5, group=G1)
manualPV  = input.float(2.0,  "Point Value ($)",   minval=0.1, step=0.5, group=G1)
contracts = input.int(1,      "Contracts",         minval=1,   step=1,   group=G1)

tpPts      = _preset == "Manual" ? manualTP : _presetTP
slPts      = _preset == "Manual" ? manualSL : _presetSL
retestPts  = _preset == "Manual" ? manualRZ : _presetRZ
pointValue = _preset == "Manual" ? manualPV : _presetPV
trailPts   = _preset == "Manual" ? 5.0 : _presetTrail

var string G_SESS = "── Session & Levels ──────────────────"
tz         = input.string("America/New_York", "Timezone", group=G_SESS)
proxThresh = input.float(10.0, "Proximity Filter (pts)", minval=0.5, step=0.5, group=G_SESS)
_proxActive = _preset == "M2K" ? math.min(proxThresh, 4.0) : proxThresh

var string G2 = "── Visuals ───────────────────────────"
showDash = input.bool(true,     "Show Dashboard",           group=G2)
showSess = input.bool(true,     "Highlight Sessions",       group=G2)
colLong  = input.color(#00c853, "Long Colour",              group=G2)
colShort = input.color(#ef5350, "Short Colour",             group=G2)
colLPM   = input.color(#1565C0, "London Pre-Market Colour", group=G2)

dollarRisk   = slPts * pointValue * contracts
dollarProfit = tpPts * pointValue * contracts

inLPM      = not na(time(timeframe.period, "0000-0300", tz))
inPM       = not na(time(timeframe.period, "0430-0930", tz))
inLondon   = not na(time(timeframe.period, "0300-0800", tz))
inNY       = not na(time(timeframe.period, "0930-1600", tz))
anySession = inLondon or inNY
inDead     = not na(time(timeframe.period, "0800-0930", tz))

bgcolor(showSess ? (inLondon ? color.new(#1565C0, 96) : inNY ? color.new(#e65100, 96) : inPM ? color.new(#4a148c, 96) : na) : na)

curDay        = dayofweek(time, tz)
var int prevDay = na
bool isNewDay   = not na(prevDay) and curDay != prevDay
prevDay        := curDay

var float dayHigh  = na, var float dayLow   = na
var float pmHigh   = na, var float pmLow    = na
var float lpmHigh  = na, var float lpmLow   = na
var float prevDayH = na, var float prevDayL = na

var line  linePDH  = na, var line  linePDL  = na
var line  linePMH  = na, var line  linePML  = na
var line  lineLPMH = na, var line  lineLPML = na
var label lblPDH   = na, var label lblPDL   = na
var label lblPMH   = na, var label lblPML   = na
var label lblLPMH  = na, var label lblLPML  = na

var int stPDH  = 0, var int stPDL  = 0
var int stPMH  = 0, var int stPML  = 0
var int stLPMH = 0, var int stLPML = 0

var int boPDH  = -1, var int boPDL  = -1
var int boPMH  = -1, var int boPML  = -1
var int boLPMH = -1, var int boLPML = -1

var int lsPDH  = -1, var int lsPDL  = -1
var int lsPMH  = -1, var int lsPML  = -1
var int lsLPMH = -1, var int lsLPML = -1

var int longCount  = 0
var int shortCount = 0

// ── Armed state lines (small horizontal marker when level arms) ──
var line armLinePDH  = na, var line armLinePDL  = na
var line armLinePMH  = na, var line armLinePML  = na
var line armLineLPMH = na, var line armLineLPML = na

f_near(a, b) =>
    not na(a) and not na(b) and math.abs(a - b) <= _proxActive

f_drawLevel(ln, lbl, lvl, col, wid, sty, txt) =>
    var line  _ln  = na
    var label _lbl = na
    _ln  := ln
    _lbl := lbl
    if na(_ln)
        _ln  := line.new(bar_index, lvl, bar_index + 1, lvl, color=col, width=wid, style=sty, extend=extend.right)
        _lbl := label.new(bar_index + 2, lvl, txt, style=label.style_label_left, textcolor=col, color=color.new(color.white, 100), size=size.small)
    else
        line.set_y1(_ln, lvl)
        line.set_y2(_ln, lvl)
        if barstate.islast
            label.set_xy(_lbl, bar_index + 2, lvl)
    [_ln, _lbl]

// ── Draw armed marker: small 4-bar line at level price ──
f_drawArmedLine(lvl, isLong) =>
    col = isLong ? color.new(colLong, 30) : color.new(colShort, 30)
    line.new(bar_index, lvl, bar_index + 4, lvl,
             color=col, width=2, style=line.style_solid)

// ── Signal box with trail markers ──
f_signal(lvl, isLong, lvlName) =>
    tp       = isLong ? lvl + tpPts  : lvl - tpPts
    sl       = isLong ? lvl - slPts  : lvl + slPts
    trail1   = isLong ? tp + trailPts : tp - trailPts
    lbY      = isLong ? lvl - slPts * 0.45 : lvl + slPts * 0.45

    box.new(bar_index, isLong ? tp : lvl, bar_index + 6, isLong ? lvl : tp,
            border_color=color.new(colLong, 40), border_width=1,
            bgcolor=color.new(colLong, 84))
    box.new(bar_index, isLong ? lvl : sl, bar_index + 6, isLong ? sl : lvl,
            border_color=color.new(colShort, 40), border_width=1,
            bgcolor=color.new(colShort, 84))
    line.new(bar_index, lvl, bar_index + 6, lvl,
             color=color.new(color.white, 30), width=1, style=line.style_solid)
    line.new(bar_index, trail1, bar_index + 6, trail1,
             color=color.new(isLong ? colLong : colShort, 20),
             width=1, style=line.style_dotted)
    label.new(bar_index, lbY,
              (isLong ? "▲  " : "▼  ") + lvlName,
              style=isLong ? label.style_label_up : label.style_label_down,
              color=isLong ? color.new(colLong, 10) : color.new(colShort, 10),
              textcolor=color.white, size=size.normal)
    label.new(bar_index + 7, tp,
              "Trail " + str.tostring(trailPts) + "pts @ TP",
              style=label.style_label_right,
              textcolor=isLong ? colLong : colShort,
              color=color.new(color.white, 100), size=size.tiny)
    label.new(bar_index + 7, trail1,
              "+5 lock",
              style=label.style_label_right,
              textcolor=color.new(isLong ? colLong : colShort, 40),
              color=color.new(color.white, 100), size=size.tiny)
    label.new(bar_index + 7, sl,
              "SL  −" + str.tostring(slPts) + "pts",
              style=label.style_label_right,
              textcolor=colShort,
              color=color.new(color.white, 100), size=size.tiny)

// ══════════════════════════════════════════════════════════════════════════════
// TRADE TRACKING - Monitors fills and outcomes (WIN/LOSS)
// ══════════════════════════════════════════════════════════════════════════════

// Track up to 6 active trades (one per level type)
var float[] tradeEntry = array.new_float(6, na)   // Entry price
var float[] tradeTP = array.new_float(6, na)      // Take profit
var float[] tradeSL = array.new_float(6, na)      // Stop loss
var bool[] tradeIsLong = array.new_bool(6, false) // Direction
var bool[] tradeFilled = array.new_bool(6, false) // Has it filled?
var string[] tradeLvlName = array.new_string(6, "")
var int[] tradeSignalId = array.new_int(6, 0)     // For matching outcomes

// Level index mapping
f_getLevelIdx(string lvlName) =>
    lvlName == "PDH" ? 0 : lvlName == "PDL" ? 1 : lvlName == "PMH" ? 2 : lvlName == "PML" ? 3 : lvlName == "LPH" ? 4 : 5

// Store a new trade for tracking
f_trackTrade(string lvlName, float entry, float tp, float sl, bool isLong) =>
    idx = f_getLevelIdx(lvlName)
    array.set(tradeEntry, idx, entry)
    array.set(tradeTP, idx, tp)
    array.set(tradeSL, idx, sl)
    array.set(tradeIsLong, idx, isLong)
    array.set(tradeFilled, idx, false)
    array.set(tradeLvlName, idx, lvlName)
    true

// Send outcome alert to ML Filter
f_sendOutcome(string lvlName, string outcome, float entryPrice, float exitPrice) =>
    if barstate.isrealtime
        // TradersPost contract symbols - must match f_sendAlert
        baseTicker = str.contains(_ticker, "MNQ") ? "MNQM2026" : str.contains(_ticker, "MES") ? "MESM2026" : str.contains(_ticker, "MGC") ? "MGCJ2026" : str.contains(_ticker, "M2K") ? "M2K" : str.contains(_ticker, "ZN") ? "ZN" : str.contains(_ticker, "ZB") ? "ZB" : str.contains(_ticker, "6E") ? "6E" : str.contains(_ticker, "6J") ? "6J" : _ticker
        pnl = outcome == "LOSS" ? -math.abs((exitPrice - entryPrice) * pointValue * contracts) : (exitPrice - entryPrice) * pointValue * contracts
        alertMsg = '{"type": "outcome", "ticker": "' + baseTicker + '", "level": "' + lvlName + '", "outcome": "' + outcome + '", "entry": ' + str.tostring(entryPrice) + ', "exit": ' + str.tostring(exitPrice) + ', "pnl": ' + str.tostring(pnl, "#.##") + ', "time": "' + str.format_time(timenow, "yyyy-MM-dd\'T\'HH:mm:ssZ", tz) + '"}'
        alert(alertMsg, alert.freq_once_per_bar)
    true

// Check all active trades for fills and outcomes
f_checkTrades() =>
    for i = 0 to 5
        entry = array.get(tradeEntry, i)
        if not na(entry)
            tp = array.get(tradeTP, i)
            sl = array.get(tradeSL, i)
            isLong = array.get(tradeIsLong, i)
            filled = array.get(tradeFilled, i)
            lvlName = array.get(tradeLvlName, i)
            // Check for fill (price touched entry)
            if not filled
                if isLong and low <= entry
                    array.set(tradeFilled, i, true)
                if not isLong and high >= entry
                    array.set(tradeFilled, i, true)
            // Only check outcomes if filled
            if array.get(tradeFilled, i)
                if isLong and high >= tp
                    f_sendOutcome(lvlName, "WIN", entry, tp)
                    array.set(tradeEntry, i, na)
                else if not isLong and low <= tp
                    f_sendOutcome(lvlName, "WIN", entry, tp)
                    array.set(tradeEntry, i, na)
                else if isLong and low <= sl
                    f_sendOutcome(lvlName, "LOSS", entry, sl)
                    array.set(tradeEntry, i, na)
                else if not isLong and high >= sl
                    f_sendOutcome(lvlName, "LOSS", entry, sl)
                    array.set(tradeEntry, i, na)
    true

// Run trade checks every bar
checkResult = f_checkTrades()

// ══════════════════════════════════════════════════════════════════════════════
// ML FILTER WEBHOOK ALERT FUNCTION
// Sends signal + indicators to ML Filter API, which decides whether to forward to TradersPost
// ══════════════════════════════════════════════════════════════════════════════
f_sendAlert(bool isLong, string lvlName, float lvlPrice) =>
    if barstate.isrealtime
        // TradersPost contract symbols - UPDATE EACH ROLLOVER
        // MES/MNQ: Quarterly (H=Mar, M=Jun, U=Sep, Z=Dec)
        // MGC: Even months (G=Feb, J=Apr, M=Jun, Q=Aug, V=Oct, Z=Dec)
        baseTicker = str.contains(_ticker, "MNQ") ? "MNQM2026" : str.contains(_ticker, "MES") ? "MESM2026" : str.contains(_ticker, "MGC") ? "MGCJ2026" : str.contains(_ticker, "M2K") ? "M2K" : str.contains(_ticker, "ZN") ? "ZN" : str.contains(_ticker, "ZB") ? "ZB" : str.contains(_ticker, "6E") ? "6E" : str.contains(_ticker, "6J") ? "6J" : _ticker
        action = isLong ? "buy" : "sell"
        session = inLondon ? "London" : inNY ? "NY" : "Other"
        tpPrice = isLong ? lvlPrice + tpPts : lvlPrice - tpPts
        slPrice = isLong ? lvlPrice - slPts : lvlPrice + slPts
        alertMsg = '{"ticker": "' + baseTicker + '", "action": "' + action + '", "level": "' + lvlName + '", "price": ' + str.tostring(lvlPrice) + ', "tp": ' + str.tostring(tpPrice) + ', "sl": ' + str.tostring(slPrice) + ', "session": "' + session + '", "rsi": ' + str.tostring(rsi_val, "#.##") + ', "rsi_roc": ' + str.tostring(rsi_roc, "#.##") + ', "macd": ' + str.tostring(macd_line, "#.####") + ', "macd_hist": ' + str.tostring(macd_hist, "#.####") + ', "plus_di": ' + str.tostring(diplus, "#.##") + ', "minus_di": ' + str.tostring(diminus, "#.##") + ', "adx": ' + str.tostring(adx_val, "#.##") + ', "atr_pct": ' + str.tostring(atr_pct, "#.###") + ', "time": "' + str.format_time(timenow, "yyyy-MM-dd\'T\'HH:mm:ssZ", tz) + '", "interval": "' + timeframe.period + '"}'
        alert(alertMsg, alert.freq_once_per_bar)
    true

// ══════════════════════════════════════════════════════════════════════════════
// CORE STATE MACHINE - MATCHES PYTHON BACKTEST ($1.12M PROFIT)
// ══════════════════════════════════════════════════════════════════════════════
// LOWS (PDL, PML, LPL): isLong=true
//   Arm: previous bar LOW > level (full bar above)
//   Fire: current bar LOW <= level + retest zone
//
// HIGHS (PDH, PMH, LPH): isLong=false
//   Arm: previous bar HIGH < level (full bar below)
//   Fire: current bar HIGH >= level - retest zone
// ══════════════════════════════════════════════════════════════════════════════

f_check(show, lvl, st, bo, ls, isLong, lvlName) =>
    _st = st, _bo = bo, _ls = ls, _fired = false, _justArmed = false

    if show and not na(lvl)

        if isLong
            // ══ LONG (PDL, PML, LPL) ══
            // Arm: pl > lvl (previous bar's low > level)
            if _st == 0 and anySession and not inDead
                if low[1] > lvl
                    _st := 1
                    _bo := bar_index
                    _justArmed := true

            // Fire: l <= lvl + rz (current low touches zone)
            if _st == 1 and bar_index > _bo
                if low <= lvl + retestPts
                    if anySession and not inDead
                        if bar_index != _ls
                            _fired := true
                            _ls := bar_index
                            _st := 2
                            f_sendAlert(true, lvlName, lvl)
                    else
                        _st := 0  // Dead zone disarm

        else
            // ══ SHORT (PDH, PMH, LPH) ══
            // Arm: ph < lvl (previous bar's high < level)
            if _st == 0 and anySession and not inDead
                if high[1] < lvl
                    _st := -1
                    _bo := bar_index
                    _justArmed := true

            // Fire: h >= lvl - rz (current high touches zone)
            if _st == -1 and bar_index > _bo
                if high >= lvl - retestPts
                    if anySession and not inDead
                        if bar_index != _ls
                            _fired := true
                            _ls := bar_index
                            _st := -2
                            f_sendAlert(false, lvlName, lvl)
                    else
                        _st := 0  // Dead zone disarm

    [_st, _bo, _ls, _fired, _justArmed]

// ── New day: full reset ───────────────────────────────────────────
if isNewDay
    prevDayH := dayHigh, prevDayL := dayLow
    dayHigh  := high,    dayLow   := low
    line.delete(linePDH),  line.delete(linePDL)
    line.delete(linePMH),  line.delete(linePML)
    line.delete(lineLPMH), line.delete(lineLPML)
    label.delete(lblPDH),  label.delete(lblPDL)
    label.delete(lblPMH),  label.delete(lblPML)
    label.delete(lblLPMH), label.delete(lblLPML)
    linePDH  := na, linePDL  := na, linePMH  := na
    linePML  := na, lineLPMH := na, lineLPML := na
    lblPDH   := na, lblPDL   := na, lblPMH   := na
    lblPML   := na, lblLPMH  := na, lblLPML  := na
    pmHigh   := na, pmLow    := na, lpmHigh  := na, lpmLow  := na
    stPDH    := 0,  stPDL    := 0,  stPMH    := 0
    stPML    := 0,  stLPMH   := 0,  stLPML   := 0
    boPDH    := -1, boPDL    := -1, boPMH    := -1
    boPML    := -1, boLPMH   := -1, boLPML   := -1
    lsPDH    := -1, lsPDL    := -1, lsPMH    := -1
    lsPML    := -1, lsLPMH   := -1, lsLPML   := -1
    longCount := 0, shortCount := 0

if not isNewDay
    dayHigh := math.max(nz(dayHigh, high), high)
    dayLow  := math.min(nz(dayLow,  low),  low)
if inLPM
    lpmHigh := na(lpmHigh) ? high : math.max(lpmHigh, high)
    lpmLow  := na(lpmLow)  ? low  : math.min(lpmLow,  low)
if inPM
    pmHigh := na(pmHigh) ? high : math.max(pmHigh, high)
    pmLow  := na(pmLow)  ? low  : math.min(pmLow,  low)

// PMH/PML only tradeable AFTER PM session ends (09:30 NY) - define first for proximity gates
showPMH  = not na(pmHigh) and not inPM
showPML  = not na(pmLow)  and not inPM

// LPH/LPL only tradeable AFTER LPM session ends (03:00 NY)
// Only check PM proximity when PM levels are actually active
showLPMH = not na(lpmHigh) and not inLPM and not (showPMH and f_near(lpmHigh, pmHigh)) and not (showPML and f_near(lpmHigh, pmLow))
showLPML = not na(lpmLow)  and not inLPM and not (showPMH and f_near(lpmLow,  pmHigh)) and not (showPML and f_near(lpmLow,  pmLow))

// PDH/PDL - only check proximity against levels that are actually being shown
showPDH  = not na(prevDayH) and not (showLPMH and f_near(prevDayH, lpmHigh)) and not (showLPML and f_near(prevDayH, lpmLow)) and not (showPMH and f_near(prevDayH, pmHigh)) and not (showPML and f_near(prevDayH, pmLow))
showPDL  = not na(prevDayL) and not (showLPMH and f_near(prevDayL, lpmHigh)) and not (showLPML and f_near(prevDayL, lpmLow)) and not (showPMH and f_near(prevDayL, pmHigh)) and not (showPML and f_near(prevDayL, pmLow))

if showPDH
    [l, b] = f_drawLevel(linePDH, lblPDH, prevDayH, color.black, 2, line.style_dashed, "PDH")
    linePDH := l, lblPDH := b
else
    line.delete(linePDH), label.delete(lblPDH), linePDH := na, lblPDH := na

if showPDL
    [l, b] = f_drawLevel(linePDL, lblPDL, prevDayL, color.black, 2, line.style_dashed, "PDL")
    linePDL := l, lblPDL := b
else
    line.delete(linePDL), label.delete(lblPDL), linePDL := na, lblPDL := na

if showLPMH
    [l, b] = f_drawLevel(lineLPMH, lblLPMH, lpmHigh, colLPM, 1, line.style_dotted, "LPH")
    lineLPMH := l, lblLPMH := b
else
    line.delete(lineLPMH), label.delete(lblLPMH), lineLPMH := na, lblLPMH := na

if showLPML
    [l, b] = f_drawLevel(lineLPML, lblLPML, lpmLow, colLPM, 1, line.style_dotted, "LPL")
    lineLPML := l, lblLPML := b
else
    line.delete(lineLPML), label.delete(lblLPML), lineLPML := na, lblLPML := na

if showPMH
    [l, b] = f_drawLevel(linePMH, lblPMH, pmHigh, color.black, 1, line.style_dotted, "PMH")
    linePMH := l, lblPMH := b
else
    line.delete(linePMH), label.delete(lblPMH), linePMH := na, lblPMH := na

if showPML
    [l, b] = f_drawLevel(linePML, lblPML, pmLow, color.black, 1, line.style_dotted, "PML")
    linePML := l, lblPML := b
else
    line.delete(linePML), label.delete(lblPML), linePML := na, lblPML := na

is15m = timeframe.period == "15"

if is15m
    // ══════════════════════════════════════════════════════════════════════════
    // MATCHES PYTHON BACKTEST ($1.12M PROFIT)
    // HIGHS (PDH, PMH, LPH) = SHORT (isLong=false)
    // LOWS  (PDL, PML, LPL) = LONG  (isLong=true)
    // ══════════════════════════════════════════════════════════════════════════

    // PDH - SHORT
    [s1,b1,l1,f1,a1] = f_check(showPDH, prevDayH, stPDH, boPDH, lsPDH, false, "PDH")
    stPDH := s1, boPDH := b1, lsPDH := l1
    if a1
        armLinePDH := f_drawArmedLine(prevDayH, false)
    if f1
        f_signal(prevDayH, false, "PDH")
        f_trackTrade("PDH", prevDayH, prevDayH - tpPts, prevDayH + slPts, false)
        shortCount += 1
        line.delete(armLinePDH)

    // PDL - LONG
    [s2,b2,l2,f2,a2] = f_check(showPDL, prevDayL, stPDL, boPDL, lsPDL, true, "PDL")
    stPDL := s2, boPDL := b2, lsPDL := l2
    if a2
        armLinePDL := f_drawArmedLine(prevDayL, true)
    if f2
        f_signal(prevDayL, true, "PDL")
        f_trackTrade("PDL", prevDayL, prevDayL + tpPts, prevDayL - slPts, true)
        longCount += 1
        line.delete(armLinePDL)

    // LPH - SHORT (HARD GATE: only process after LPM session ends at 03:00)
    if not inLPM
        [s3,b3,l3,f3,a3] = f_check(showLPMH, lpmHigh, stLPMH, boLPMH, lsLPMH, false, "LPH")
        stLPMH := s3, boLPMH := b3, lsLPMH := l3
        if a3
            armLineLPMH := f_drawArmedLine(lpmHigh, false)
        if f3
            f_signal(lpmHigh, false, "LPH")
            f_trackTrade("LPH", lpmHigh, lpmHigh - tpPts, lpmHigh + slPts, false)
            shortCount += 1
            line.delete(armLineLPMH)

    // LPL - LONG (HARD GATE: only process after LPM session ends at 03:00)
    if not inLPM
        [s4,b4,l4,f4,a4] = f_check(showLPML, lpmLow, stLPML, boLPML, lsLPML, true, "LPL")
        stLPML := s4, boLPML := b4, lsLPML := l4
        if a4
            armLineLPML := f_drawArmedLine(lpmLow, true)
        if f4
            f_signal(lpmLow, true, "LPL")
            f_trackTrade("LPL", lpmLow, lpmLow + tpPts, lpmLow - slPts, true)
            longCount += 1
            line.delete(armLineLPML)

    // PMH - SHORT (HARD GATE: only process after PM session ends at 09:30)
    if not inPM
        [s5,b5,l5,f5,a5] = f_check(showPMH, pmHigh, stPMH, boPMH, lsPMH, false, "PMH")
        stPMH := s5, boPMH := b5, lsPMH := l5
        if a5
            armLinePMH := f_drawArmedLine(pmHigh, false)
        if f5
            f_signal(pmHigh, false, "PMH")
            f_trackTrade("PMH", pmHigh, pmHigh - tpPts, pmHigh + slPts, false)
            shortCount += 1
            line.delete(armLinePMH)

    // PML - LONG (HARD GATE: only process after PM session ends at 09:30)
    if not inPM
        [s6,b6,l6,f6,a6] = f_check(showPML, pmLow, stPML, boPML, lsPML, true, "PML")
        stPML := s6, boPML := b6, lsPML := l6
        if a6
            armLinePML := f_drawArmedLine(pmLow, true)
        if f6
            f_signal(pmLow, true, "PML")
            f_trackTrade("PML", pmLow, pmLow + tpPts, pmLow - slPts, true)
            longCount += 1
            line.delete(armLinePML)

// ── Dashboard ─────────────────────────────────────────────────────────────────
var table dash = na

if showDash and barstate.islast
    if na(dash)
        dash := table.new(position.top_right, 2, 9, bgcolor=color.black,
                          border_color=color.new(color.white, 75), border_width=1,
                          frame_color=color.new(color.white, 75), frame_width=1)

    table.cell(dash, 0, 0, "THE EDGE", bgcolor=color.black, text_color=color.white,
               text_size=size.small, text_halign=text.align_left, width=12)
    table.cell(dash, 1, 0, _preset, bgcolor=color.black,
               text_color=color.new(color.white, 55), text_size=size.small,
               text_halign=text.align_right, width=8)

    table.cell(dash, 0, 1, "", bgcolor=color.new(color.white, 75), height=1)
    table.cell(dash, 1, 1, "", bgcolor=color.new(color.white, 75), height=1)

    table.cell(dash, 0, 2, "  Stop Loss", bgcolor=color.black,
               text_color=color.new(color.white, 55), text_size=size.small,
               text_halign=text.align_left)
    table.cell(dash, 1, 2, "−" + str.tostring(slPts) + " pts", bgcolor=color.black,
               text_color=color.white, text_size=size.small, text_halign=text.align_right)

    table.cell(dash, 0, 3, "  Take Profit", bgcolor=color.black,
               text_color=color.new(color.white, 55), text_size=size.small,
               text_halign=text.align_left)
    table.cell(dash, 1, 3, "+" + str.tostring(tpPts) + " pts", bgcolor=color.black,
               text_color=color.white, text_size=size.small, text_halign=text.align_right)

    table.cell(dash, 0, 4, "  Trail", bgcolor=color.black,
               text_color=color.new(color.white, 55), text_size=size.small,
               text_halign=text.align_left)
    table.cell(dash, 1, 4, str.tostring(trailPts) + " pts @ TP", bgcolor=color.black,
               text_color=color.white, text_size=size.small, text_halign=text.align_right)

    table.cell(dash, 0, 5, "", bgcolor=color.new(color.white, 85), height=1)
    table.cell(dash, 1, 5, "", bgcolor=color.new(color.white, 85), height=1)

    table.cell(dash, 0, 6, "  Risk", bgcolor=color.black,
               text_color=color.new(color.white, 55), text_size=size.small,
               text_halign=text.align_left)
    table.cell(dash, 1, 6, "$" + str.tostring(dollarRisk), bgcolor=color.black,
               text_color=color.white, text_size=size.small, text_halign=text.align_right)

    table.cell(dash, 0, 7, "  Target", bgcolor=color.black,
               text_color=color.new(color.white, 55), text_size=size.small,
               text_halign=text.align_left)
    table.cell(dash, 1, 7, "$" + str.tostring(dollarProfit), bgcolor=color.black,
               text_color=color.white, text_size=size.small, text_halign=text.align_right)

    table.cell(dash, 0, 8, "  " + syminfo.ticker, bgcolor=color.black,
               text_color=color.new(color.white, 75), text_size=size.tiny,
               text_halign=text.align_left)
    table.cell(dash, 1, 8, "$" + str.tostring(pointValue) + " × " + str.tostring(contracts) + "ct",
               bgcolor=color.black, text_color=color.new(color.white, 75),
               text_size=size.tiny, text_halign=text.align_right)

if barstate.islast and not is15m
    label.new(bar_index, high, "⚠  Switch to 15-min for signals",
              style=label.style_label_left, color=color.red, textcolor=color.white, size=size.normal)
